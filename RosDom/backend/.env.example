HOST=0.0.0.0
PORT=4000
CORS_ORIGIN=*

ROSDOM_RUNTIME_MODE=real
ROSDOM_PROCESS_ROLE=api
ROSDOM_DB_DRIVER=postgres

JWT_ACCESS_SECRET=change-me-to-a-long-random-secret

# Prefer DATABASE_URL in production. If it is empty, POSTGRES_* values are used.
DATABASE_URL=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=rosdom
POSTGRES_USER=rosdom
POSTGRES_PASSWORD=change-me
POSTGRES_SSL_MODE=disable
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000

# Smart Life / Tuya cloud project credentials.
# Use the Access ID / Access Secret from your Tuya Cloud project overview.
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
TUYA_DEFAULT_REGION=eu

# Primary production flow for an existing Smart Life account.
# 1. Link the app account to the cloud project in Tuya Console.
# 2. Sign in from RosDom with the existing Smart Life username/password.
TUYA_ASSOCIATED_APP_SCHEMA=tuyaSmart
TUYA_REQUEST_IDENTIFIER=tuyaSmart
TUYA_APP_SCHEMA=tuyaSmart

# Optional legacy OEM OAuth flow. Leave empty unless you really use the OEM app flow.
TUYA_APP_AUTH_IDENTIFIER=
TUYA_REDIRECT_URL=
TUYA_AUTHORIZATION_URL=
TUYA_AUTHORIZATION_URL_TEMPLATE=
ROSDOM_APP_DEEP_LINK_URL=ru.rosdom://integrations/tuya/callback

# 32-byte raw string or 32-byte base64 value used to encrypt provider tokens.
INTEGRATION_CREDENTIALS_SECRET=

REDIS_URL=redis://127.0.0.1:6379
MQTT_URL=mqtt://127.0.0.1:1883
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rosdom-media
