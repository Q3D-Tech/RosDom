HOST=0.0.0.0
PORT=4000
CORS_ORIGIN=https://YOUR_DOMAIN

ROSDOM_RUNTIME_MODE=real
ROSDOM_PROCESS_ROLE=api
ROSDOM_DB_DRIVER=postgres

JWT_ACCESS_SECRET=PUT_A_LONG_RANDOM_SECRET_HERE

# Prefer DATABASE_URL in production.
DATABASE_URL=postgres://rosdom:CHANGE_ME@127.0.0.1:5432/rosdom
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=rosdom
POSTGRES_USER=rosdom
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_SSL_MODE=disable
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000

# Smart Life / Tuya cloud project credentials.
# Use the Access ID / Access Secret from the Tuya Cloud project overview.
TUYA_CLIENT_ID=PUT_TUYA_ACCESS_ID_HERE
TUYA_CLIENT_SECRET=PUT_TUYA_ACCESS_SECRET_HERE
TUYA_DEFAULT_REGION=eu

# Primary production flow for an existing Smart Life account.
TUYA_ASSOCIATED_APP_SCHEMA=tuyaSmart
TUYA_REQUEST_IDENTIFIER=tuyaSmart
TUYA_APP_SCHEMA=tuyaSmart

# Optional legacy OEM OAuth flow. Leave empty unless you still use it.
TUYA_APP_AUTH_IDENTIFIER=
TUYA_REDIRECT_URL=
TUYA_AUTHORIZATION_URL=
TUYA_AUTHORIZATION_URL_TEMPLATE=
ROSDOM_APP_DEEP_LINK_URL=ru.rosdom://integrations/tuya/callback

# 32-byte raw string or 32-byte base64 value.
INTEGRATION_CREDENTIALS_SECRET=PUT_32_BYTE_SECRET_OR_BASE64_HERE

REDIS_URL=redis://127.0.0.1:6379
MQTT_URL=mqtt://127.0.0.1:1883
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rosdom-media
